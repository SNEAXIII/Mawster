{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "app/lib/placeholder-data.ts",
    "build/types/**/*.ts",
    "next-env.d.ts",
    "scripts/seed.js",
    "next-build/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    ".next-*/types/**/*.ts",
    ".next-*/dev/types/**/*.ts",
    ".next-e2e/types/**/*.ts",
    ".next-e2e/dev/types/**/*.ts",
    ".next-3012/types/**/*.ts",
    ".next-3012/dev/types/**/*.ts",
    ".next-3013/types/**/*.ts",
    ".next-3013/dev/types/**/*.ts",
    ".next-3011/types/**/*.ts",
    ".next-3011/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
