# Copier en `stack-app-dev.env` sur le VPS et remplir. NE PAS COMMITER le fichier rempli
# (déjà ignoré par la règle `*.env` du .gitignore).

# --- Base de données (tier dev) ---
MARIADB_PASSWORD=change-me
MARIADB_ROOT_PASSWORD=change-me-root

# --- API ---
SECRET_KEY=change-me-jwt-secret
EMAIL_PEPPER=change-me-pepper

# --- Front / NextAuth ---
NEXTAUTH_SECRET=change-me-nextauth
DISCORD_CLIENT_ID=reuse-prod-discord-id
DISCORD_CLIENT_SECRET=reuse-prod-discord-secret
GOOGLE_CLIENT_ID=reuse-prod-google-id
GOOGLE_CLIENT_SECRET=reuse-prod-google-secret

# --- Basic-auth Traefik (hash htpasswd bcrypt) ---
# Générer : htpasswd -nbB testeur 'monMotDePasse'
# Single-quote OBLIGATOIRE : le `. ./stack-app-dev.env` interpolerait sinon les '$' du hash.
DEV_BASIC_AUTH='testeur:$2y$05$exampleexampleexampleexampleexampleexampleex'
