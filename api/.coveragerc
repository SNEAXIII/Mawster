[run]
source = src
omit =
    */__init__.py
    tests/*
    migrations/*
    scripts/*
    src/fixtures/*
    src/utils/logging_config.py
    src/controllers/dev_controller.py   
concurrency =
    greenlet
    thread

[report]
exclude_also =
    if TYPE_CHECKING:
    def custom_openapi():
    def __str__\(self\):