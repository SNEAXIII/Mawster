{
  "mcpServers": {
    "cypress-runner": {
      "type": "stdio",
      "command": "cmd",
      "args": ["/c", "cd mcp && npx tsx cypress-runner/index.ts"]
    },
    "pytest-runner": {
      "type": "stdio",
      "command": "cmd",
      "args": ["/c", "cd mcp && npx tsx pytest-runner/index.ts"]
    },
    "context-mode": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/start.mjs"]
    },
    "github": {
      "type": "stdio",
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    }
  }
}
